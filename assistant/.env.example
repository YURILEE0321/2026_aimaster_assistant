## LLM 프로바이더 선택: gemini | azure (노드 코드 변경 없이 전환)
LLM_PROVIDER=azure

## Google Gemini (LLM_PROVIDER=gemini일 때 사용)
GOOGLE_API_KEY=
MODEL_NAME=gemini-3.5-flash
EMBEDDING_MODEL=gemini-embedding-001

## Azure OpenAI (LLM_PROVIDER=azure일 때 사용)
AZURE_API_KEY=
AZURE_ENDPOINT=
AZURE_API_VERSION=2024-12-01-preview
AZURE_CHAT_DEPLOYMENT=gpt-4.1
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large

## 우리 자체 메타데이터 DB (wiki_documents 테이블)
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<db>

## backend-proxy가 쓰는 Postgres (documents/wikimd 테이블을 읽기 전용으로 조회)
## backend-proxy/.env의 DATABASE_URL과 같은 값을 쓰면 된다.
PROXY_DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<db>
## Neon 등 풀링 커넥션에서 documents/wikimd가 기본(public) 스키마가 아닌 별도 스키마에 있을 때만 설정.
## 예: PROXY_DB_SEARCH_PATH=wikidb,public (필요 없으면 비워둔다)
PROXY_DB_SEARCH_PATH=

## Qdrant (우리 자체 컬렉션 + backend-proxy Builder가 적재한 컬렉션, 같은 클러스터를 공유)
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=ai_wiki_chunks
PROXY_QDRANT_SUMMARY_COLLECTION=wiki_summary
PROXY_QDRANT_CHUNK_COLLECTION=wiki_chunk
## wiki_summary/wiki_chunk를 만든 임베딩 모델과 반드시 일치해야 벡터 차원이 맞는다.
PROXY_EMBEDDING_MODEL=aitl-prd-text-embedding-3-small
PROXY_TOP_K_SUMMARY=5
PROXY_TOP_K_CHUNK=8

## 검색/재시도 튜닝값
TOP_K=5
RERANK_TOP_N=3
CONFIDENCE_THRESHOLD=0.7
MAX_RETRIES=3
## 멀티턴 대화(window memory): Question Analyzer에 넘길 최근 대화 턴 수(1턴 = 사용자+어시스턴트 한 쌍).
HISTORY_WINDOW_TURNS=5

## FastAPI 서버 (backend-proxy의 ASSISTANT_API_BASE_URL 기본값이 127.0.0.1:8001)
PORT=8001
LOG_LEVEL=INFO
